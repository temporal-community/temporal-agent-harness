# Scoped justfile for the Monty travel-agent example (examples/monty).
# Run from this directory: `just <recipe>`.
#
# Self-contained: the session-manager recipes (the session-manager worker + the web chat UI that
# drives these agents) are imported from examples/session_manager, so a full local run is doable
# entirely from here — four terminals:
#   just temporal          # 1. local Temporal dev server (or bring your own)
#   just session-manager   # 2. session-manager worker      (imported from examples/session_manager)
#   just server            # 3. FastAPI chat UI on :8000    (imported from examples/session_manager)
#   just worker            # 4. this example's agent worker
#
# uv installs the project's `examples` dependency group (pydantic-monty + the Gemini SDK) on
# demand, so there's no separate install step. First-time setup: `cp .env.example .env.local`
# and fill it in (Temporal connection + GEMINI_API_KEY). See README.md.

# Let this file's `default` override the one imported from session_manager (otherwise the
# duplicate is an error). Without our own `default` first, just's "run the first recipe"
# behavior on a bare `just` would pick `worker` instead of listing.
set allow-duplicate-recipes := true

import '../session_manager/justfile'

# List available recipes (bare `just`).
default:
    @just --list

# Run the Monty example agent worker (MontyDynamicAgent + the two conversational agents).
worker:
    cd "{{root}}" && uv run --group examples python -m examples.monty.worker

# Install the Svelte app dependencies.
app-install:
    pnpm --dir app install

# Type-check the Svelte app and run the local Svelte 5 syntax guard.
app-check:
    pnpm --dir app run check
    pnpm --dir app run check:svelte5

# Build the Svelte app into app/dist.
app-build:
    pnpm --dir app run build

# Run the Svelte app on Vite. /api is proxied to the FastAPI server on :8000.
app-dev:
    pnpm --dir app run dev
