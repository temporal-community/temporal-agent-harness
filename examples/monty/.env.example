# Environment for the Monty example. Copy this file to `.env.local` (gitignored) and edit it:
#
#     cp .env.example .env.local
#
# The justfile auto-loads `.env.local` for every recipe, so these become environment variables
# the worker / session-manager / server all see. Nothing is passed on the command line.

# --- Temporal connection ----------------------------------------------------------------------
# Path to a temporal.toml-format config (https://docs.temporal.io/cli#environment-configuration)
# holding your connection profiles. Resolved relative to the repo root (the recipes run there).
#
# The committed ../../temporal.local.toml ships a `default` profile pointing at a local dev server
# (`just temporal`). To run against your own server or Temporal Cloud, point this at a private
# file instead — create ../../temporal.toml (gitignored), add a profile with your
# address/namespace/api_key, and set TEMPORAL_CONFIG_FILE=temporal.toml below.
TEMPORAL_CONFIG_FILE=temporal.local.toml

# Which profile in that file to use.
TEMPORAL_PROFILE=default

# --- OpenAI -----------------------------------------------------------------------------------
# Required: the conversational Monty agents call the OpenAI API via the OpenAI Agents SDK.
OPENAI_API_KEY=

# --- Large-payload offload --------------------------------------------------------------------
# Monty sandbox snapshots can exceed Temporal's ~2 MB payload limit, so they're offloaded to
# external storage. "local" (filesystem) is fine for single-host local dev; use "s3" for
# multi-host deploys (then set LARGE_PAYLOAD_S3_BUCKET — see temporal_agent_harness/utils/large_payload.py).
LARGE_PAYLOAD_DRIVER=local
