# Environment for the Chronicler example. Copy this file to `.env.local` (gitignored) and edit:
#
#     cp .env.example .env.local
#
# The justfile auto-loads `.env.local` for every recipe, so these become environment variables
# the worker / session-manager / server all see.

# --- Temporal connection ----------------------------------------------------------------------
# Path to a temporal.toml-format config holding your connection profiles, resolved relative to
# the repo root. The committed ../../temporal.local.toml ships a `default` profile pointing at a
# local dev server (`just temporal`). For your own server / Temporal Cloud, create ../../temporal.toml
# (gitignored) and point this at it.
TEMPORAL_CONFIG_FILE=temporal.local.toml
TEMPORAL_PROFILE=default

# --- Gemini -----------------------------------------------------------------------------------
# Required: transcription, summarization, entity extraction, and TTS all call Gemini.
GEMINI_API_KEY=

# Optional model overrides (defaults shown). Audio/TTS model availability varies by API access —
# override if a default isn't available on your key.
# CHRONICLER_TRANSCRIBE_MODEL=gemini-3.5-flash
# CHRONICLER_SUMMARY_MODEL=gemini-3.5-flash
# CHRONICLER_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- Notifications --------------------------------------------------------------------------
# Channel for "transcription ready" pings. "inapp" (default) surfaces in the UI as a tool event
# + is echoed in the agent's reply. "webhook" POSTs {"text": "..."} to CHRONICLER_WEBHOOK_URL
# (Slack/Discord/any) for a real out-of-band ping.
CHRONICLER_NOTIFIER=inapp
# CHRONICLER_WEBHOOK_URL=

# --- Large-payload offload --------------------------------------------------------------------
# Transcripts/audio can exceed Temporal's ~2 MB payload limit, so they're offloaded to external
# storage. "local" (filesystem) is fine for single-host local dev.
LARGE_PAYLOAD_DRIVER=local
