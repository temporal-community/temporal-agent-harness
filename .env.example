# Shared environment for the bundled examples. Copy this file to `.env.local` (gitignored) at the
# repo root and edit it:
#
#     cp .env.example .env.local
#
# The root justfile auto-loads `.env.local` for every recipe (and the per-example justfiles read
# this same root file via dotenv-path), so these become environment variables the worker /
# session-manager / server all see. Nothing is passed on the command line.

# --- Temporal connection ----------------------------------------------------------------------
# Path to a temporal.toml-format config (https://docs.temporal.io/cli#environment-configuration)
# holding your connection profiles. Resolved relative to the repo root (the recipes run there).
#
# The committed temporal.local.toml ships a `default` profile pointing at a local dev server
# (`just temporal`). To run against your own server or Temporal Cloud, point this at a private
# file instead — create temporal.toml (gitignored), add a profile with your
# address/namespace/api_key, and set TEMPORAL_CONFIG_FILE=temporal.toml below.
TEMPORAL_CONFIG_FILE=temporal.local.toml

# Which profile in that file to use.
TEMPORAL_PROFILE=default

# --- Gemini -----------------------------------------------------------------------------------
# Required by the Gemini-backed example agents (Monty chat, the wiki keeper) — they call the
# Gemini API. Leave blank if you're only running the OpenAI example.
GEMINI_API_KEY=

# --- OpenAI -----------------------------------------------------------------------------------
# Required by the OpenAI Agents example (examples/openai_hello) — its model activities call the
# OpenAI API. Leave blank if you're only running the Gemini-backed examples.
OPENAI_API_KEY=

# --- Daytona ------------------------------------------------------------------------------------
# Required only if examples/sandboxed_tool_demo/tools.py's SANDBOX is switched from the default
# Subprocess() backend to Daytona(...) (see that file). Leave blank otherwise — the demo's default
# Subprocess backend needs no API key at all.
DAYTONA_API_KEY=

# --- Large-payload offload --------------------------------------------------------------------
# Some payloads (e.g. Monty sandbox snapshots) can exceed Temporal's ~2 MB limit, so they're
# offloaded to external storage. "local" (filesystem) is fine for single-host local dev; use "s3"
# for multi-host deploys (then set LARGE_PAYLOAD_S3_BUCKET — see
# temporal_agent_harness/utils/large_payload.py).
LARGE_PAYLOAD_DRIVER=local
